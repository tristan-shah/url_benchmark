<mujoco model="humanoid_standup_minimalist">
  <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>

  <option integrator="implicitfast" timestep="0.01" gravity="0 0 -9.81"/>

  <default>
    <joint armature="0.01" damping="2" limited="false"/>
    <geom conaffinity="0" contype="0" material="geom" rgba="0.8 0.6 .4 1"/>
    <motor ctrllimited="true" ctrlrange="-1.0 1.0" gear="100"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="100" height="100"/>
    <texture builtin="flat" name="texgeom" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127" height="1278"/>
    <material name="geom" texture="texgeom"/>
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="0 0 -1" directional="true" pos="0 0 4" specular=".1 .1 .1"/>

    <body name="left_anchor" pos="-0.15 0 0.05">
        <geom name="l_anchor_geom" type="sphere" size="0.01" rgba="0.5 0.5 0.5 0.2"/>
    </body>
    <body name="right_anchor" pos="0.15 0 0.05">
        <geom name="r_anchor_geom" type="sphere" size="0.01" rgba="0.5 0.5 0.5 0.2"/>
    </body>

    <body name="pelvis" pos="0 0 0.8">
      <camera name="side" pos="0 -3 1" euler="90 0 0" mode="trackcom"/>
      <joint name="root_x" type="slide" axis="1 0 0" armature="0" damping="0"/>
      <joint name="root_z" type="slide" axis="0 0 1" armature="0" damping="0"/>
      <geom name="pelvis_geom" type="capsule" fromto="-0.12 0 0 0.12 0 0" size="0.07"/>

      <body name="torso" pos="0 0 0">
        <joint name="waist" type="hinge" axis="0 1 0"/>
        <geom name="torso_geom" type="capsule" fromto="0 0 0 0 0 0.4" size="0.07"/>
        
        <body name="head" pos="0 0 0.45">
          <geom name="head_geom" type="sphere" size="0.1"/>
        </body>

        <body name="left_arm" pos="-0.15 0 0.35">
          <joint name="l_shoulder" type="hinge" axis="0 1 0"/>
          <geom name="l_arm_geom" type="capsule" fromto="0 0 0 0 0 -0.25" size="0.04"/>
          <body name="left_forearm" pos="0 0 -0.25">
            <joint name="l_elbow" type="hinge" axis="0 1 0"/>
            <geom name="l_forearm_geom" type="capsule" fromto="0 0 0 0 0 -0.2" size="0.03"/>
          </body>
        </body>

        <body name="right_arm" pos="0.15 0 0.35">
          <joint name="r_shoulder" type="hinge" axis="0 1 0"/>
          <geom name="r_arm_geom" type="capsule" fromto="0 0 0 0 0 -0.25" size="0.04"/>
          <body name="right_forearm" pos="0 0 -0.25">
            <joint name="r_elbow" type="hinge" axis="0 1 0"/>
            <geom name="r_forearm_geom" type="capsule" fromto="0 0 0 0 0 -0.2" size="0.03"/>
          </body>
        </body>
      </body>

      <body name="left_thigh" pos="-0.15 0 0">
        <joint name="l_hip" type="hinge" axis="0 1 0"/>
        <geom name="l_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.35" size="0.05"/>
        <body name="left_shin" pos="0 0 -0.35">
          <joint name="l_knee" type="hinge" axis="0 1 0"/>
          <geom name="l_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.35" size="0.04"/>
          <body name="left_foot" pos="0 0 -0.35">
            <joint name="l_ankle" type="hinge" axis="0 1 0"/>
            <geom name="l_foot_geom" type="capsule" fromto="-0.05 0 0 0.1 0 0" size="0.03"/>
          </body>
        </body>
      </body>

      <body name="right_thigh" pos="0.15 0 0">
        <joint name="r_hip" type="hinge" axis="0 1 0"/>
        <geom name="r_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.35" size="0.05"/>
        <body name="right_shin" pos="0 0 -0.35">
          <joint name="r_knee" type="hinge" axis="0 1 0"/>
          <geom name="r_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.35" size="0.04"/>
          <body name="right_foot" pos="0 0 -0.35">
            <joint name="r_ankle" type="hinge" axis="0 1 0"/>
            <geom name="r_foot_geom" type="capsule" fromto="-0.05 0 0 0.1 0 0" size="0.03"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <weld body1="left_foot" body2="left_anchor" solref="0.01 1" solimp=".9 .9 0.01"/>
    <weld body1="right_foot" body2="right_anchor" solref="0.01 1" solimp=".9 .9 0.01"/>
  </equality>

  <actuator>
    <motor name="m_waist" joint="waist"/>
    <motor name="m_l_shoulder" joint="l_shoulder"/>
    <motor name="m_r_shoulder" joint="r_shoulder"/>
    <motor name="m_l_hip" joint="l_hip"/>
    <motor name="m_l_knee" joint="l_knee"/>
    <motor name="m_l_ankle" joint="l_ankle"/>
    <motor name="m_r_hip" joint="r_hip"/>
    <motor name="m_r_knee" joint="r_knee"/>
    <motor name="m_r_ankle" joint="r_ankle"/>
  </actuator>
</mujoco>