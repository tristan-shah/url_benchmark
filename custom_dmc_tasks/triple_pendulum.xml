<mujoco model="triple_pendulum_no_contact">
  <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
  
  <option integrator="implicitfast" timestep="0.01"/>

  <default>
    <joint armature="0.01" damping="1" limited="false"/>
    <geom conaffinity="0" contype="0" margin="0.001" material="geom" rgba="0.8 0.6 .4 1" solimp=".8 .8 .01" solref=".02 1"/>
    <motor ctrllimited="true" ctrlrange="-1.0 1.0" gear="25"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".4 .5 .6" rgb2="0 0 0" width="100" height="100"/>
    <texture builtin="checker" height="100" name="texplane" rgb1="0 0 0" rgb2="0.8 0.8 0.8" type="2d" width="100"/>
    <material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="60 60" texture="texplane"/>
    <texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1" name="texgeom" random="0.01" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127"/>
    <material name="geom" texture="texgeom" texuniform="true"/>
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="0 0 -1" directional="true" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom conaffinity="1" condim="3" name="floor" pos="0 0 0" rgba="0.8 0.9 0.8 1" size="20 20 .125" type="plane" material="MatPlane"/>
    
    <body name="foot" pos="0 0 1.5">
      <geom friction="2.0" fromto="-0.13 0 0 0.26 0 0" name="foot_geom" size="0.06" type="capsule"/>
      
      <body name="leg" pos="0 0 0">
        <joint axis="0 -1 0" name="foot_joint" pos="0 0 0" type="hinge"/>
        <geom friction="0.9" fromto="0 0 0 0 0 0.5" name="leg_geom" size="0.04" type="capsule"/>
        
        <body name="thigh" pos="0 0 0.5">
          <joint axis="0 -1 0" name="leg_joint" pos="0 0 0" type="hinge"/>
          <geom friction="0.9" fromto="0 0 0 0 0 0.45" name="thigh_geom" size="0.05" type="capsule"/>
          
          <body name="torso" pos="0 0 0.45">
            <camera name="track" mode="trackcom" pos="0 -3 1" xyaxes="1 0 0 0 0 1"/>
            <joint axis="0 -1 0" name="thigh_joint" pos="0 0 0" type="hinge"/>
            <geom friction="0.9" fromto="0 0 0 0 0 0.4" name="torso_geom" size="0.05" type="capsule"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor joint="thigh_joint" name="thigh_motor" ctrlrange="-1 1"/>
    <motor joint="leg_joint" name="leg_motor" ctrlrange="-1 1"/>
    <motor joint="foot_joint" name="foot_motor" ctrlrange="-1 1"/>
  </actuator>
</mujoco>